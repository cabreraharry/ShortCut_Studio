node_modules/
out/
dist/
release-builds/
*.log
.DS_Store
.vite/

# SQLite DBs and backups — data, not code
db_files/*.db
db_files/*.backup.*.db

# Env
.env
.env.local
.env.*.local
tsconfig.*.tsbuildinfo

# Storybook screenshots — regenerated by `npm run storybook`
storybook/screenshots/

# Vendor binaries — fetched on demand by scripts/fetch-vendor-binaries.mjs.
# IPFS Kubo + Nginx are no longer bundled into the installer (the v0.5.0+
# web stub fetches them at install time), but the script still populates
# this dir for `npm run dev` / `build:unpack` developer workflows.
vendor/

# NSIS plugins fetched by scripts/fetch-nsis-plugins.mjs at build time.
# Cached zips + extracted DLLs both go under build/plugins/. Refresh by
# deleting the dir and running `npm run fetch-nsis-plugins`.
build/plugins/

# Optional-component SHA-256 values, generated by
# scripts/fetch-optional-components.mjs from the cached installer .exes.
# installer.nsh !includes this file at build time. Regenerated each build;
# do not commit (would only encode this maintainer's last cached version).
build/component-shas.nsh
